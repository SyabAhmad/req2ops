# ─── App Metadata ───────────────────────────────────────────
APP_NAME=Req2Ops AI
APP_DESCRIPTION=Turn messy client requirements into structured execution plans
APP_VERSION=0.1.0
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,https://your-production-domain.com

# ─── Environment ────────────────────────────────────────────
APP_ENV=development        # development | production | staging
DEBUG=true                 # false in production
SECRET_KEY=change-me-to-a-random-secret

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/req2ops

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── LLM ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk-...
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq          # openai | groq
LLM_TEMPERATURE=0.3

# ─── Upload ─────────────────────────────────────────────────
ALLOWED_FILE_EXTENSIONS=.pdf,.txt,.mp3,.wav,.m4a,.png,.jpg,.jpeg,.gif,.webp
MAX_FILE_SIZE_MB=10
