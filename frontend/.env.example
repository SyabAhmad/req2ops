# ─── Backend API ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_API_PREFIX=/api/v1
VITE_API_PROJECTS_PATH=/projects
VITE_API_UPLOAD_PATH=/upload
VITE_API_WORKSPACE_PATH=/workspace

# ─── Upload Form ─────────────────────────────────────────────
VITE_UPLOAD_ACCEPT=.pdf,.txt
VITE_UPLOAD_PLACEHOLDER=Paste client requirements, email, WhatsApp notes here...
VITE_UPLOAD_BTN_LABEL=Generate Execution Plan
VITE_UPLOAD_FILE_BTN=Upload PDF

# ─── Workspace Tabs (JSON array) ──────────────────────────────
# Each tab: {"key": "...", "label": "..."}
# Keys must match workspace data fields:
#   dev      → dev_plan
#   design   → design_plan
#   tasks    → task_graph
#   risks    → understanding
#   actions  → control_layer
VITE_WORKSPACE_TABS=[{"key":"dev","label":"Developer View"},{"key":"design","label":"Designer View"},{"key":"tasks","label":"Tasks"},{"key":"risks","label":"Risks / Missing Info"},{"key":"actions","label":"Next Actions"}]
